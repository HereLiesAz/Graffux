<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Photo import for editing. Graffux is a 2D sketch & photo editor today; ARCore is pulled in
         (transitively, for the SLAM/XR groundwork) but declared optional below, so the 2D editor runs
         on any device and the XR path is gated at runtime. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".GraffuxApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Graffux">

        <!--
            ARCore is optional. Graffux ships as a 2D editor, but the ARCore AAR is a
            transitive dependency (SlamManager, isArCoreAvailable, and the XR groundwork
            that will eventually serve XR users). The AAR injects
            com.google.ar.core.min_apk_version, and ARCore requires a matching
            com.google.ar.core dependency-type tag or it throws at runtime. "optional"
            means Google Play does not filter the listing to ARCore-eligible devices and
            does not auto-install the ARCore APK; XR features are gated at runtime via
            ArCoreApk.checkAvailability().
        -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Graffux">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Interop: receive an image shared from GraffitiXR (e.g. a captured wall photo) to edit. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
        </activity>

        <!-- Interop (share-out): exposes the edited PNG in cacheDir/shared as a content:// Uri so it
             can be sent back to GraffitiXR (or any app) via ACTION_SEND. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
