<resources>

    <string name="app_name">GraffitiXR</string>


    <string name="nav_modes">模式</string>

    <string name="nav_modes_info">在 AR 投影、覆盖、效果图和追踪模式之间切换。</string>


    <string name="nav_ar_mode">AR</string>

    <string name="nav_ar_mode_info">使用增强现实将您的艺术作品投影到真实的墙壁上。首先扫描墙壁以放置锚点，然后添加您的设计图层。</string>


    <string name="nav_overlay">覆盖</string>

    <string name="nav_overlay_info">在实时相机画面上覆盖您的设计，无需 AR 锚点。非常适合快速构图和位置检查。</string>


    <string name="nav_mockup">效果图</string>

    <string name="nav_mockup_info">在墙壁的静态照片上预览您的设计合成效果。无需相机或扫描。</string>


    <string name="nav_trace">追踪</string>

    <string name="nav_trace_info">将您的设计用作透写台覆盖层，以便将参考线描绘到物理表面上。</string>

    <string name="nav_trace_mode">透写台</string>


    <string name="nav_canvas">画布</string>

    <string name="nav_mural">壁画</string>

    <string name="nav_scan_mode_toggle_info">在画布（针对较小的桌面级艺术作品进行了优化）和壁画（针对大型墙壁和高斯泼溅进行了优化）扫描模式之间切换。</string>


    <string name="nav_stencil">模板</string>

    <string name="nav_stencil_info">从您的艺术作品生成可打印的多层模板。每一层都作为纯轮廓平铺打印，尺寸适合美国信纸。</string>


    <string name="nav_grid">目标</string>

    <string name="nav_grid_info">创建和管理 AR 锚点目标。拍摄墙上绘制的参考标记照片以将投影锁定到位。</string>


    <string name="nav_surveyor">测量</string>

    <string name="nav_surveyor_info">映射墙壁表面以提高 AR 追踪的准确性。</string>


    <string name="nav_create">创建</string>

    <string name="nav_create_info">拍摄墙壁上的参考标记以创建一个新的 AR 锚点。应用程序将跟踪此标记以保持您的投影对齐。</string>


    <string name="nav_refine">微调</string>

    <string name="nav_refine_info">微调现有 AR 锚点目标的位置。</string>


    <string name="nav_update">进度</string>

    <string name="nav_update_info">标记壁画的已完成区域以跟踪绘画进度。</string>


    <string name="nav_design">设计</string>

    <string name="nav_design_info">添加和管理设计图层。每个图层可以是导入的图像或手绘图。</string>


    <string name="nav_open">打开</string>

    <string name="nav_open_info">从您的图库中添加一张图片作为新图层。</string>


    <string name="nav_wall">墙壁</string>

    <string name="nav_wall_info">替换效果图模式中使用的背景墙照片。</string>


    <string name="nav_isolate">分离</string>

    <string name="nav_isolate_info">自动从此图层中移除背景，仅将主体留在透明背景上。</string>


    <string name="nav_invert">反色</string>

    <string name="nav_invert_info">创建当前图层的负片。黑色变为白色，颜色反转为其补色 — 适用于模板和覆盖层分析。</string>


    <string name="nav_outline">轮廓</string>

    <string name="nav_outline_info">将此图层转换为透明背景上的黑色线稿 — 非常适合创建模板。</string>


    <string name="nav_adjust">调整</string>

    <string name="nav_adjust_info">微调此图层的亮度、对比度、饱和度和色彩平衡。</string>


    <string name="nav_balance">颜色</string>

    <string name="nav_balance_info">使用红、绿、蓝通道滑块对图层颜色进行着色。</string>


    <string name="nav_blending">混合</string>

    <string name="nav_blending_info">循环切换混合模式（正常、正片叠底、滤色、叠加…）以控制此图层与下方图层的合成方式。</string>


    <string name="nav_settings">设置</string>

    <string name="nav_settings_info">配置用手习惯、AR 扫描模式、单位和其他应用程序首选项。</string>


    <string name="nav_project">项目</string>

    <string name="nav_project_info">管理您的项目：创建、保存、加载和导出。</string>


    <string name="nav_new">新建</string>

    <string name="nav_new_info">开始全新的空项目。任何未保存的更改都将丢失。</string>


    <string name="nav_save">保存</string>

    <string name="nav_save_info">将当前项目保存到您的设备。</string>


    <string name="nav_load">加载</string>

    <string name="nav_load_info">打开项目库以加载以前保存的项目。</string>


    <string name="nav_export">导出</string>

    <string name="nav_export_info">将所有可见图层合并后导出为一张平面图像到您的照片库。</string>


    <string name="nav_help">帮助</string>

    <string name="nav_help_info">在帮助处于活动状态时点按任何按钮可查看其功能。</string>


    <string name="nav_light">灯光</string>

    <string name="nav_light_info">在弱光下工作时，切换设备手电筒以照亮您的墙壁。</string>


    <string name="nav_lock">锁定</string>

    <string name="nav_lock_info">锁定触摸屏以防止在喷漆时发生意外更改。在任意位置连按三次即可解锁。</string>



    <string name="info_brush">在此图层上手绘笔触。向上/向下拖动“大小”按钮以更改画笔直径；向左/向右拖动以调整羽化（边缘柔和度）。</string>

    <string name="info_eraser">使用圆形画笔擦除此图层的部分内容。向上/向下拖动“大小”按钮以更改直径；向左/向右拖动以调整羽化。</string>

    <string name="info_blur">涂抹并柔化此图层的区域。拖动以模糊一个区域。</string>

    <string name="info_liquify">在任何方向推拉和扭曲像素。拖动一个区域使其变形 — 适用于调整比例。</string>

    <string name="info_dodge">通过在上面绘画来变亮特定区域。</string>

    <string name="info_burn">通过在上面绘画来变暗特定区域。</string>

    <string name="info_size">向上/向下拖动以更改画笔直径。向左/向右拖动以调整羽化 — 羽化越大，边缘越柔和，更像喷漆罐的效果。</string>

    <string name="info_color">显示活动的画笔颜色。向上/向下拖动以调整亮度；向左/向右拖动以调整饱和度。点按即可打开完整的色轮。</string>

    <string name="info_draw">添加一个新的透明空白图层以进行手绘。</string>

    <string name="info_keyframe">将当前的 AR 相机姿态保存为关键帧。用于纠正漂移并在离开并返回后重新对齐投影。</string>

    <string name="info_layer">此图层。点按可激活它。打开水平栏以访问工具。长按并拖动可重新排序。</string>



    <string name="stencil_layers">图层</string>

    <string name="stencil_layers_info">选择要生成的模板图层数：1（仅轮廓）、2（轮廓 + 高光）或 3（轮廓 + 中间调 + 高光）。</string>


    <string name="stencil_rebuild">重建</string>

    <string name="stencil_rebuild_info">在当前源图层上重新运行模板生成管道。</string>


    <string name="stencil_print">打印</string>

    <string name="stencil_print_info">配置真实世界的打印尺寸并为美国信纸生成平铺的 PDF。</string>


    <string name="stencil_print_size">尺寸</string>

    <string name="stencil_print_size_info">向上/向下拖动以设置模板的真实世界宽度或高度（以厘米为单位）。页数实时更新。</string>


    <string name="stencil_print_dim_toggle">宽 / 高</string>

    <string name="stencil_print_dim_toggle_info">点按以在锁定输出的宽度或高度之间切换。</string>


    <string name="stencil_export_pdf">打印 PDF</string>

    <string name="stencil_export_pdf_info">生成所有模板图层的平铺 PDF，准备打印和切割。每个平铺都包含 3 毫米的重叠部分，以便于组装对齐。</string>


    <string name="stencil_save_layers">保存 PNG</string>

    <string name="stencil_save_layers_info">将每个模板图层另存为单独的 PNG 图像到您的图库中。</string>


    <string name="stencil_back">← 编辑器</string>

    <string name="stencil_back_info">返回主编辑器。您的模板图层保留在会话中。</string>


