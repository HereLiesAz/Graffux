<?xml version='1.0' encoding='utf-8'?>
<resources>

    <string name="app_name">塗鴉XR</string>


    <string name="nav_modes">模式</string>

    <string name="nav_modes_info">在 AR 投影、疊加、模型和追蹤模式之間切換。</string>


    <string name="nav_ar_mode">擴增實境</string>

    <string name="nav_ar_mode_info">使用擴增實境將您的藝術作品投影到真實的牆上。首先掃描牆壁以放置錨點，然後添加您的設計圖層。</string>


    <string name="nav_overlay">覆蓋</string>

    <string name="nav_overlay_info">將您的設計疊加在即時攝影機畫面上，無需 AR 錨定。非常適合快速取景和位置檢查。</string>


    <string name="nav_mockup">小樣</string>

    <string name="nav_mockup_info">預覽合成到牆壁照片上的設計。無需相機或掃描。</string>


    <string name="nav_trace">痕跡</string>

    <string name="nav_trace_info">將您的設計用作光台覆蓋層，以在物理表面上追蹤參考線。</string>

    <string name="nav_trace_mode">燈箱</string>


    <string name="nav_canvas">畫布</string>

    <string name="nav_mural">壁畫</string>

    <string name="nav_scan_mode_toggle_info">在畫布（針對較小的桌面尺寸藝術進行了最佳化）和壁畫（針對大型牆壁和高斯潑濺進行了最佳化）之間切換。</string>


    <string name="nav_stencil">模版</string>

    <string name="nav_stencil_info">從您的藝術品生成可列印的多層模板。每層列印為僅輪廓圖塊，尺寸適合美國信紙。</string>


    <string name="nav_grid">目標</string>

    <string name="nav_grid_info">建立和管理 AR 錨點目標。照片在牆上畫了參考標記，以將投影鎖定到位。</string>


    <string name="nav_surveyor">民調</string>

    <string name="nav_surveyor_info">繪製牆面地圖以提高 AR 追蹤精度。</string>


    <string name="nav_create">創造</string>

    <string name="nav_create_info">拍攝牆上的參考標記以建立新的 AR 錨點。該應用程式將追蹤此標記以保持您的投影對齊。</string>


    <string name="nav_refine">精煉</string>

    <string name="nav_refine_info">微調現有 AR 錨點目標的位置。</string>


    <string name="nav_update">進步</string>

    <string name="nav_update_info">標記壁畫的已完成區域以追蹤繪畫進度。</string>


    <string name="nav_design">設計</string>

    <string name="nav_design_info">新增和管理設計圖層。每個圖層可以是匯入的影像或手繪圖。</string>


    <string name="nav_open">打開</string>

    <string name="nav_open_info">新增圖庫中的圖像作為新圖層。</string>


    <string name="nav_wall">牆</string>

    <string name="nav_wall_info">取代Mockup模式下所使用的背景牆照片。</string>


    <string name="nav_isolate">隔離</string>

    <string name="nav_isolate_info">自動從此圖層中刪除背景，僅將主體保留在透明背景上。</string>


    <string name="nav_invert">倒置</string>

    <string name="nav_invert_info">建立目前圖層的負片。黑色變成白色，顏色翻轉為相反的顏色 - 對於模板和疊加分析非常有用。</string>


    <string name="nav_outline">大綱</string>

    <string name="nav_outline_info">將此圖層轉換為透明背景上的黑色線條藝術 - 非常適合創建模板模板。</string>


    <string name="nav_adjust">調整</string>

    <string name="nav_adjust_info">微調此圖層的亮度、對比、飽和度和色彩平衡。</string>


    <string name="nav_balance">顏色</string>

    <string name="nav_balance_info">使用紅色、綠色和藍色通道滑桿對圖層顏色進行著色。</string>


    <string name="nav_blending">混合</string>

    <string name="nav_blending_info">循環切換混合模式（普通、正片疊底、濾色、疊加…）以控制此圖層與下方圖層的合成方式。</string>


    <string name="nav_settings">設定</string>

    <string name="nav_settings_info">配置慣用手、AR 掃描模式、單位和其他應用程式首選項。</string>


    <string name="nav_project">專案</string>

    <string name="nav_project_info">管理您的專案：建立、儲存、載入和匯出。</string>


    <string name="nav_new">新的</string>

    <string name="nav_new_info">啟動新的空項目。任何未儲存的變更都將遺失。</string>


    <string name="nav_save">儲存</string>

    <string name="nav_save_info">將目前項目儲存到您的裝置。</string>


    <string name="nav_load">載入</string>

    <string name="nav_load_info">打開項目庫以載入先前儲存的項目。</string>


    <string name="nav_export">匯出</string>

    <string name="nav_export_info">將所有可見圖層的平面合併影像匯出到您的照片庫。</string>


    <string name="nav_help">幫助</string>

    <string name="nav_help_info">當「幫助」處於活動狀態時，點擊任一按鈕即可查看其功能。</string>


    <string name="nav_light">光</string>

    <string name="nav_light_info">在低光源條件下工作時，切換設備手電筒以照亮牆壁。</string>


    <string name="nav_lock">鎖</string>

    <string name="nav_lock_info">鎖定觸控螢幕以防止噴塗時發生意外變更。在任何位置點擊三次即可解鎖。</string>



    <string name="info_brush">在該圖層上徒手繪製筆觸。向上/向下拖曳「大小」按鈕可變更畫筆直徑；向左/向右拖曳以調整羽化（邊緣柔和度）。</string>

    <string name="info_eraser">用圓形畫筆擦除該圖層的部分內容。向上/向下拖曳“尺寸”按鈕可更改直徑；向左/向右拖曳以調整羽化。</string>

    <string name="info_blur">塗抹並軟化該層的區域。拖曳過某個區域以使其模糊。</string>

    <string name="info_liquify">向任意方向推動和扭曲像素。在某個區域上拖曳可使其變形－對於調整比例很有用。</string>

    <string name="info_dodge">透過在特定區域上繪畫來照亮它們。</string>

    <string name="info_burn">透過在特定區域上繪畫來使它們變暗。</string>

    <string name="info_size">向上/向下拖曳以更改畫筆直徑。向左/向右拖曳以調整羽化 - 較寬的羽化可提供更柔和、更像噴霧罐的邊緣。</string>

    <string name="info_color">顯示活動畫筆顏色。上下拖曳可調整亮度；向左/向右拖曳以調整飽和度。點擊可打開全色輪。</string>

    <string name="info_draw">增加一個新的空白透明圖層用於手繪。</string>

    <string name="info_keyframe">將目前 AR 相機姿勢儲存為關鍵影格。用於在離開和返回後校正漂移並重新對齊投影。</string>

    <string name="info_layer">這一層。點擊以激活它。打開水平導軌即可使用工具。長按並拖曳可重新排序。</string>



    <string name="stencil_layers">層數</string>

    <string name="stencil_layers_info">選擇要產生的模板層數：1（僅輪廓）、2（輪廓 + 高光）或 3（輪廓 + 中間調 + 高光）。</string>


    <string name="stencil_rebuild">重建</string>

    <string name="stencil_rebuild_info">在目前來源層上重新執行模板產生管道。</string>


    <string name="stencil_print">列印</string>

    <string name="stencil_print_info">配置實際列印尺寸並為 US Letter 紙產生平鋪 PDF。</string>


    <string name="stencil_print_size">尺寸</string>

    <string name="stencil_print_size_info">向上/向下拖曳以設定模板的實際寬度或高度（以公分為單位）。頁數即時更新。</string>


    <string name="stencil_print_dim_toggle">寬/高</string>

    <string name="stencil_print_dim_toggle_info">點擊可在鎖定輸出的寬度或高度之間切換。</string>


    <string name="stencil_export_pdf">列印 PDF</string>

    <string name="stencil_export_pdf_info">產生所有模板層的平鋪 PDF，準備列印和切割。每個磁磚都有 3 毫米的重疊部分，用於組裝對齊。</string>


    <string name="stencil_save_layers">保存 PNG</string>

    <string name="stencil_save_layers_info">將每個模板層作為單獨的 PNG 圖像儲存到您的圖庫中。</string>


    <string name="stencil_back">← 編輯</string>

    <string name="stencil_back_info">返回主編輯器。您的模板層將保留在會話中。</string>


